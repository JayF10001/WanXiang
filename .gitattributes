# Competition packaging: keep runtime assets, but drop documentation and bulky non-code assets from archives.
/docs/ export-ignore
/csv/ export-ignore
/paper/ export-ignore
/storage/ export-ignore
/frontend_new/dist/ export-ignore
/.vite/ export-ignore

# Root-level handoff and deployment docs.
/*.md export-ignore
/*.txt export-ignore
/*.docx export-ignore

# Module documentation files.
README*.md export-ignore
readme*.md export-ignore
CODE_OF_CONDUCT.md export-ignore
TESTING_GUIDE.md export-ignore

# Windows download marker files should never be shipped.
*Zone.Identifier export-ignore
