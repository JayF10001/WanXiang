# WanXiang shared environment template
#
# Usage:
# 1. Local teammate machine: cp .env.example .env.local
# 2. Server/container deployment: cp .env.example .env
# 3. Fill in real secrets and addresses before starting the stack

# --------------------------------------------------------------------
# Required: core backend
# --------------------------------------------------------------------
SECRET_KEY=replace-with-a-random-secret
MONGODB_URI=mongodb://127.0.0.1:27017/chatdb
DB_NAME=chatdb
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# --------------------------------------------------------------------
# Required: cross-service addresses
# Local development should keep VITE_FRONTEND_API_BASE=/api to preserve
# same-origin cookies through the Vite proxy.
# --------------------------------------------------------------------
CHATBACKEND_BASE_URL=http://127.0.0.1:5000
FRONTEND_API_BASE_URL=http://127.0.0.1:8001/api
FRONTEND_ORIGIN=http://127.0.0.1:3000
WANXIANG_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
VITE_FRONTEND_API_BASE=/api

# --------------------------------------------------------------------
# Required: model/provider keys
# Fill at least one available provider for the main chat chain.
# --------------------------------------------------------------------
ACTIVE_PROVIDER=
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3-max
QWEN_FALLBACK_MODEL=qwen-max
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# --------------------------------------------------------------------
# Optional: external capability keys
# GOOGLE_API_KEY is used by Gemini video/multimodal flows.
# TAVILY_API_KEY is used by LangChain/Tavily search enhancement.
# --------------------------------------------------------------------
GOOGLE_API_KEY=
TAVILY_API_KEY=
WANXIANG_SEARCH_TRUST_ENV=false
# WANXIANG_TAVILY_TRUST_ENV=false
# WANXIANG_DDG_TRUST_ENV=false

# --------------------------------------------------------------------
# Optional: hot news upstream overrides
# Use these when public defaults are unavailable in your network, or when
# you self-host a compatible dailyhot/ikunpay replacement.
# --------------------------------------------------------------------
HOTNEWS_DAILYHOT_BASE_URL=https://api-hot.imsyy.top
HOTNEWS_IKUNPAY_BASE_URL=https://api.ikunpay.com
NEWS_API_BASE_URL=https://api.vvhan.com/api/hotlist/all

# --------------------------------------------------------------------
# Recommended: runtime storage
# Server deployments should point this to a persistent mounted path.
# --------------------------------------------------------------------
WANXIANG_RUNTIME_STORAGE_ROOT=./storage/runtime
# WANXIANG_MULTIMODAL_STORAGE=./storage/runtime/multimodal
# WANXIANG_TTS_STORAGE=./storage/runtime/tts

# --------------------------------------------------------------------
# Optional: PDF fallback fonts
# Comma-separated font candidates. Leave empty to use the built-in
# Linux + legacy WSL fallback list.
# --------------------------------------------------------------------
WANXIANG_REPORT_FONT_PATHS=

# --------------------------------------------------------------------
# Optional: robot adapters
# Keep empty unless the adapter needs an override different from the
# shared FRONTEND_API_BASE_URL.
# --------------------------------------------------------------------
FEISHU_FRONTEND_API_BASE_URL=
QQ_FRONTEND_API_BASE_URL=
